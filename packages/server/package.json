{
  "name": "@remote-dom/server",
  "version": "0.1.0",
  "description": "DOM streaming server — headless Chrome sessions over WebSocket",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["dom", "streaming", "puppeteer", "headless", "chrome", "websocket", "remote"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rlyshw/remdom.git",
    "directory": "packages/server"
  },
  "dependencies": {
    "@remote-dom/protocol": "workspace:*",
    "linkedom": "^0.18.0",
    "puppeteer-core": "^24.0.0",
    "ws": "^8.18.0"
  },
  "optionalDependencies": {
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "peerDependencies": {
    "puppeteer-core": ">=22.0.0"
  },
  "peerDependenciesMeta": {
    "puppeteer-core": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/ws": "^8.5.0",
    "typescript": "^5.7.0"
  }
}
